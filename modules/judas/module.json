{
    "name": "judas",
    "description": "Judas flag keyword Source Code grabber from directories",
    "entry": "judas_wrapper.sh",
    "options": {
        "HOST": {
            "required": true
        },
        "PORT": {
            "required": true
        },
        "FILE": {
            "required": true
        },
        "KEYWORD": {
            "required": true
        },
        "SCHEME": {
            "required": false,
            "default": "http"
        }
    },
        "argument_order": [
        "HOST",
        "PORT",
        "FILE",
        "KEYWORD",
        "SCHEME"
    ]
}
